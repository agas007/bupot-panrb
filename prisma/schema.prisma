// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Colleague {
  id                    Int                         @id @default(autoincrement())
  username              String                      @unique
  password              String
  name                  String                      @unique
  role                  String                      @default("USER") // ADMIN or USER
  records               SPMRecord[]
  notifications         Notification[]
  reconciliationPeriods TaxReconciliationPeriod[]   @relation("ReconciliationCreatedBy")
  createdAt             DateTime                    @default(now())
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      Colleague @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String    // INFO, WARNING, SUCCESS, DANGER
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model SPMRecord {
  id              Int       @id @default(autoincrement())
  // Identification (from Excel merging)
  uniqueKey       String    @unique // Combination of spmNumber + accountCode + deductionAmount
  spmNumber       String
  spmDate         DateTime
  accountCode     String
  deductionAmount Float
  
  // Details (from the two source excels)
  sp2dNumber      String?
  sp2dDate        DateTime?
  description     String?
  recipient       String?
  totalValue      Float?
  
  // Tracking
  status          String    @default("PENDING") // PENDING, COMPLETED
  assigneeId      Int?
  assignee        Colleague? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  completionDate  DateTime?
  docLink         String?
  notes           String?
  
  // Metadata
  importDate      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userName  String
  action    String
  target    String
  category  String   @default("GENERAL") // AUTH, DATA, ADMIN, SECURITY, GENERAL
  type      String   // info, success, warning, danger
  createdAt DateTime @default(now())
}

model TaxReconciliationPeriod {
  id          Int                        @id @default(autoincrement())
  year        Int
  month       Int
  title       String?
  notes       String?
  status      String                     @default("DRAFT")
  createdById Int?
  createdBy   Colleague?                  @relation("ReconciliationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  targets     TaxReconciliationTarget[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@unique([year, month])
  @@index([year, month])
}

model TaxReconciliationTarget {
  id          Int                       @id @default(autoincrement())
  periodId    Int
  period      TaxReconciliationPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  accountCode String
  coretaxAmount Float
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([periodId, accountCode])
  @@index([accountCode])
}
